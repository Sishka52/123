    dropdownBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    dropdownBtn.Text = defaultValue
    dropdownBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropdownBtn.TextSize = 12
    dropdownBtn.Font = Enum.Font.Gotham
