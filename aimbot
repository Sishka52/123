-- Initialize Aimbot
function Aimbot:Initialize(character)
    if not character then 
        warn("Aimbot: Invalid character")
        return 
    end
    
    self.Character = character
    self:FindFirstTarget()

    if self.Settings.AutoAim then
        self:EnableAutoAim()
    end
    
    print("✅ Aimbot initialized")
end

-- Find Target
function Aimbot:FindFirstTarget()
    if not self.Character then return end
    
    local closestTarget = nil
    local closestDistance = self.Settings.TargetDistance
    local myPosition = self.Character:FindFirstChild("HumanoidRootPart")
    
    if not myPosition then return end
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local targetChar = otherPlayer.Character
            local humanoid = targetChar:FindFirstChild("Humanoid")
            local rootPart = targetChar:FindFirstChild("HumanoidRootPart")
            
            -- Проверка условий
            if humanoid and humanoid.Health > 0 and rootPart then
                -- Team Check
                if self.Settings.TeamCheck and otherPlayer.Team == player.Team then
                    continue
                end
                
                local distance = (myPosition.Position - rootPart.Position).Magnitude
                
                -- Visible Check
                if self.Settings.VisibleCheck then
                    local ray = Ray.new(camera.CFrame.Position, (rootPart.Position - camera.CFrame.Position).Unit * distance)
                    local hit, _ = workspace:FindPartOnRayWithIgnoreList(ray, {self.Character, camera})
                    if hit and not hit:IsDescendantOf(targetChar) then
                        continue
                    end
                end
                
                if distance < closestDistance then
                    closestDistance = distance
                    closestTarget = targetChar
                end
            end
        end
    end
    
    self.CurrentTarget = closestTarget
    
    if self.Settings.ShowTarget and closestTarget then
        self:CreateTargetHighlight()
    elseif self.TargetHandle then
        self.TargetHandle:Destroy()
        self.TargetHandle = nil
    end
end

-- Enable Auto-Aim
function Aimbot:EnableAutoAim()
    local connection = RunService.Heartbeat:Connect(function()
        if not self.Settings.Enabled or not self.Character or not camera then return end

        local humanoid = self.Character:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then return end

        if self.CurrentTarget then
            self:AdjustCameraToTarget(self.CurrentTarget)
        else
            self:FindFirstTarget()
        end
    end)
    
    table.insert(self.Connections, connection)
end

-- Adjust Camera
function Aimbot:AdjustCameraToTarget(target)
    if not target or not camera then return end
    
    local targetPart = target:FindFirstChild(self.Settings.AimAtHead and "Head" or "HumanoidRootPart")
    if not targetPart then return end
    
    local targetPosition = targetPart.Position
    if self.Settings.AimAtHead then
        targetPosition = targetPosition + Vector3.new(0, 0.5, 0)
    end
    
    local targetCFrame = CFrame.new(
        camera.CFrame.Position,
        targetPosition
    )
    
    -- Smooth camera movement
    camera.CFrame = camera.CFrame:Lerp(targetCFrame, self.Settings.Smoothness)
end

-- Create Target Highlight
function Aimbot:CreateTargetHighlight()
    if self.TargetHandle then
        self.TargetHandle:Destroy()
    end
    
    local target = self.CurrentTarget
    if not target then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "TargetHighlight"
    highlight.Adornee = target
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillColor = Color3.fromRGB(255, 50, 50)
    highlight.FillTransparency = 0.3
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = target

    self.TargetHandle = highlight
end

-- Toggle functions
function Aimbot:Toggle(enabled)
    self.Settings.Enabled = enabled
    if not enabled then
        if self.TargetHandle then
            self.TargetHandle:Destroy()
            self.TargetHandle = nil
        end
        self.CurrentTarget = nil
    end
    print("Aimbot:", enabled and "ON" or "OFF")
end

function Aimbot:UpdateSetting(setting, value)
    self.Settings[setting] = value
    print(setting .. ":", value)
end

-- Stop function
function Aimbot:Stop()
    if self.TargetHandle then
        self.TargetHandle:Destroy()
        self.TargetHandle = nil
    end
    
    for _, connection in ipairs(self.Connections) do
        connection:Disconnect()
    end
    self.Connections = {}
    
    self.CurrentTarget = nil
    print("Aimbot stopped")
end

